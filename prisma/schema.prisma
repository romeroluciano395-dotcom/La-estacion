// Esquema Prisma — La Estación
// Base de datos: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Conexión pooled (para la app; evita agotar conexiones en serverless).
  url       = env("DATABASE_URL")
  // Conexión directa (para migraciones). En local puede ser la misma.
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  editor
}

enum EventCategory {
  recitales
  turismo
  deportivos
  aeropuertos
  privados
  empresas
  especiales
}

enum EventStatus {
  disponible
  ultimos_lugares
  agotado
  proximamente
  cancelado
}

enum ReservationStatus {
  pendiente
  confirmada
  cancelada
  finalizada
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(admin)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id                String        @id @default(cuid())
  slug              String        @unique
  title             String
  shortDescription  String
  description        String       @db.Text
  price             Int
  date              DateTime      @db.Date
  time              String
  city              String
  departureLocation String
  category          EventCategory
  status            EventStatus   @default(disponible)
  availableSeats    Int           @default(0)
  totalSeats        Int           @default(0)
  featured          Boolean       @default(false)
  coverImage        String
  gallery           String[]
  latitude          Float         @default(-34.6037)
  longitude         Float         @default(-58.3816)
  importantInfo     String[]
  faqs              Json?
  reservations      Reservation[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([category])
  @@index([status])
  @@index([featured])
  @@index([date])
}

model Reservation {
  id        String            @id @default(cuid())
  firstName String
  lastName  String
  dni       String
  phone     String
  email     String
  quantity  Int               @default(1)
  notes     String?
  status    ReservationStatus @default(pendiente)
  event     Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@index([eventId])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}

model Settings {
  id             String @id @default(cuid())
  companyName    String
  description    String
  phone          String
  whatsapp       String
  email          String
  instagram      String
  facebook       String
  address        String
  hours          String
  logo           String
  primaryColor   String
  secondaryColor String
}
