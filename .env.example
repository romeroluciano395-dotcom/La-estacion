# ─────────────────────────────────────────────────────────────
#  La Estación — Variables de entorno
#  Copiá este archivo como `.env` y completá los valores.
# ─────────────────────────────────────────────────────────────

# Base de datos (PostgreSQL)
# DATABASE_URL = conexión de la app. En serverless (Vercel + Neon) usá la
#   conexión "pooled" (el host incluye "-pooler") para no agotar conexiones.
# DIRECT_URL  = conexión directa, usada por las migraciones.
#   En local (Postgres propio) ambas pueden ser la misma.
DATABASE_URL="postgresql://usuario:password@localhost:5432/la_estacion?schema=public"
DIRECT_URL="postgresql://usuario:password@localhost:5432/la_estacion?schema=public"

# URL pública del sitio (metadata, sitemap, canonical, Open Graph)
NEXT_PUBLIC_SITE_URL="http://localhost:3070"

# Auth.js / NextAuth
# Generar el secreto con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="reemplazar-por-un-secreto-largo-y-aleatorio"
NEXTAUTH_SECRET="reemplazar-por-un-secreto-largo-y-aleatorio"
NEXTAUTH_URL="http://localhost:3070"
AUTH_URL="http://localhost:3070"
AUTH_TRUST_HOST="true"

# Cloudinary (opcional — al completarlo se activa la subida real de imágenes)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
